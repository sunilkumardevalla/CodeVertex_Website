#!/bin/sh
set -e

# Auto-push every new commit to the current branch on origin.
# Disable temporarily with:
#   git config --local hooks.autopush.enabled false
if [ "$(git config --local --get hooks.autopush.enabled || echo true)" = "false" ]; then
  exit 0
fi

branch="$(git rev-parse --abbrev-ref HEAD)"
[ "$branch" = "HEAD" ] && exit 0

remote="$(git config --local --get hooks.autopush.remote || echo origin)"

git push "$remote" "$branch"

# Mirror MFI clone changes into the dedicated MFI repository.
# Disable with:
#   git config --local hooks.mfi-mirror.enabled false
if [ "$(git config --local --get hooks.mfi-mirror.enabled || echo true)" = "true" ]; then
  if git diff-tree --no-commit-id --name-only -r HEAD | grep -Eq '^dev/(mfi-website|Mfi-Website)/'; then
    repo_root="$(git rev-parse --show-toplevel)"
    "$repo_root/scripts/push-mfi-mirror.sh" "Mirror from CodeVertex commit $(git rev-parse --short HEAD)"
  fi
fi
