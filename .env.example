# Core request signature verification (incoming requests to your API)
CV_WEBHOOK_SIGNING_SECRET=replace-with-a-long-random-secret

# Optional: sign payloads sent to downstream CRM/marketing webhooks
CV_DOWNSTREAM_SIGNING_SECRET=replace-with-a-downstream-signing-secret

# CRM provider: webhook | hubspot
CV_CRM_PROVIDER=hubspot

# HubSpot direct CRM delivery (recommended for production)
CV_HUBSPOT_PRIVATE_APP_TOKEN=replace-with-hubspot-private-app-token
CV_HUBSPOT_API_BASE=https://api.hubapi.com
CV_HUBSPOT_TIMEOUT_MS=7000
CV_HUBSPOT_LIFECYCLE_STAGE=lead
CV_HUBSPOT_DEFAULT_LEAD_STATUS=NEW
CV_HUBSPOT_HIGH_PRIORITY_LEAD_STATUS=OPEN
CV_HUBSPOT_NURTURE_LEAD_STATUS=IN_PROGRESS

# CRM routing destinations (used when CV_CRM_PROVIDER=webhook or as fallback if set)
CV_CRM_ENTERPRISE_WEBHOOK=https://example.com/hooks/crm-enterprise
CV_CRM_PRIMARY_WEBHOOK=https://example.com/hooks/crm-primary
CV_CRM_SECONDARY_WEBHOOK=https://example.com/hooks/crm-secondary

# Marketing routing destinations
CV_MARKETING_URGENT_WEBHOOK=https://example.com/hooks/marketing-urgent
CV_MARKETING_PRIMARY_WEBHOOK=https://example.com/hooks/marketing-primary
CV_MARKETING_SECONDARY_WEBHOOK=https://example.com/hooks/marketing-secondary

# Dead-letter queue fallback webhook (optional)
CV_DEAD_LETTER_WEBHOOK=https://example.com/hooks/dead-letter

# Routing controls
CV_ROUTER_MAX_ATTEMPTS=3
CV_ROUTER_BASE_DELAY_MS=400
CV_FAIL_ON_ROUTING_ERROR=false

# Origin control for API endpoints (comma-separated)
CV_ALLOWED_ORIGINS=https://codevertex.io,https://www.codevertex.io,http://localhost:8888,http://localhost:3000

# Temporary debugging flag (set true only during routing diagnostics)
CV_EXPOSE_ROUTING_DEBUG=false
